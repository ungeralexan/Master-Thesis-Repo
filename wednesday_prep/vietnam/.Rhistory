echo    = TRUE,
message = FALSE,
warning = FALSE,
fig.width  = 11,
fig.height = 5.5
)
library(haven)       # read .dta
library(AER)         # ivreg() for 2SLS
library(sandwich)    # HC1 robust variance
library(lmtest)      # coeftest()
library(OutcomeWeights) # dml_with_smoother(), get_outcome_weights()
library(cobalt)      # love.plot()
library(viridis)     # colour palette
library(gridExtra)   # grid.arrange()
library(ggplot2)
library(knitr)
library(kableExtra)
# All kappa estimators, DML helpers, weight diagnostics — sourced from the
# shared library. No function is defined in this notebook.
source("functions_all.R")
cat("functions_all.R sourced successfully.\n")
# --- Load & clean SIPP data (N = 3,027, replicating SUW Table 2) ---
data_path <- "/Users/alexung/desktop/suw_jbes_replicate"
sipp      <- read_dta(file.path(data_path, "sipp.dta"))
sipp_clean <- sipp[sipp$rsncode != 999 &
!is.na(sipp$educ) &
!is.na(sipp$kwage), ]
# Age polynomial terms
sipp_clean$age  <- sipp_clean$age_5
sipp_clean$age2 <- sipp_clean$age_5^2
sipp_clean$age3 <- sipp_clean$age_5^3
# Outcome: log wages in two units (key for translation-invariance demo)
sipp_clean$lwage     <- log(sipp_clean$kwage)          # dollars
sipp_clean$lwage_cnt <- log(100 * sipp_clean$kwage)    # cents = lwage + log(100)
# Age factor for saturated specification
sipp_clean$age_fac <- factor(sipp_clean$age_5)
# Core vectors
Z_sipp <- as.integer(sipp_clean$eligible)  # draft lottery instrument
D_sipp <- as.integer(sipp_clean$nvstat)    # veteran status
Y_dol  <- sipp_clean$lwage
Y_cnt  <- sipp_clean$lwage_cnt
k      <- log(100)                         # shift constant for TI check
cat(sprintf("N = %d (should be 3,027) | mean(D) = %.3f | mean(Z) = %.3f\n",
nrow(sipp_clean), mean(D_sipp), mean(Z_sipp)))
Z_sipp
View(sipp)
View(sipp_clean)
# --- Load & clean SIPP data (N = 3,027, replicating SUW Table 2) ---
data_path <- "/Users/alexung/desktop/suw_jbes_replicate"
sipp      <- read_dta(file.path(data_path, "sipp.dta"))
sipp_clean <- sipp[sipp$rsncode != 999 &
!is.na(sipp$educ) &
!is.na(sipp$kwage), ]
# Age polynomial terms
sipp_clean$age  <- sipp_clean$age_5
sipp_clean$age2 <- sipp_clean$age_5^2
sipp_clean$age3 <- sipp_clean$age_5^3
# Outcome: log wages in two units (key for translation-invariance demo)
sipp_clean$lwage     <- log(sipp_clean$kwage)          # dollars
sipp_clean$lwage_cnt <- log(100 * sipp_clean$kwage)    # cents = lwage + log(100)
# Age factor for saturated specification
sipp_clean$age_fac <- factor(sipp_clean$age_5)
# Core vectors
Z_sipp <- as.integer(sipp_clean$rsncode)  # draft lottery instrument
D_sipp <- as.integer(sipp_clean$nvstat)    # veteran status
Y_dol  <- sipp_clean$lwage
Y_cnt  <- sipp_clean$lwage_cnt
k      <- log(100)                         # shift constant for TI check
cat(sprintf("N = %d (should be 3,027) | mean(D) = %.3f | mean(Z) = %.3f\n",
nrow(sipp_clean), mean(D_sipp), mean(Z_sipp)))
# --- Kappa covariate matrices (with intercept, for logit MLE / CBPS) ---
X1 <- model.matrix(~ age,                       data = sipp_clean)
X2 <- model.matrix(~ age + I(age^2) + I(age^3), data = sipp_clean)
X3 <- model.matrix(~ age_fac,                   data = sipp_clean)
# --- DML covariate matrices (no intercept, stripped for grf) ---
X_dml_cub <- make_X(~ 0 + age + I(age^2) + I(age^3), sipp_clean)
X_dml_sat_full <- make_X(~ 0 + age_fac, sipp_clean)
X_dml_sat      <- X_dml_sat_full[, -1, drop = FALSE]   # drop reference level
# --- Data frames for 2SLS (no intercept) ---
X1_df <- as.data.frame(X1[, -1, drop = FALSE])
X2_df <- as.data.frame(X2[, -1, drop = FALSE])
X3_df <- as.data.frame(X3[, -1, drop = FALSE])
cat("Design matrices ready.\n")
specs <- list(
list(name = "Linear age",    X = X1, X_df = X1_df),
list(name = "Cubic age",     X = X2, X_df = X2_df),
list(name = "Saturated age", X = X3, X_df = X3_df)
)
rows <- list()
for (s in specs) {
for (outcome in c("lwage_cnt", "lwage")) {
Y     <- sipp_clean[[outcome]]
label <- if (outcome == "lwage_cnt") "Cents" else "Dollars"
iv  <- run_2sls(Y, D_sipp, Z_sipp, s$X_df, endog_name = "nvstat")
res <- kappa_analytic_se_all(Y, Z_sipp, D_sipp, s$X)
add_row <- function(estimator, est, se, norm_label) {
pval  <- 2 * pnorm(-abs(est / se))
tval  <- est / se
stars <- ifelse(pval < 0.01, "***", ifelse(pval < 0.05, "**",
ifelse(pval < 0.10, "*", "")))
rows[[length(rows) + 1]] <<- data.frame(
Specification  = s$name,
Outcome        = label,
Estimator      = estimator,
Normalized     = norm_label,
Estimate       = round(est, 4),
SE             = round(se, 4),
`t-value`      = round(tval, 2),
Sig            = stars,
stringsAsFactors = FALSE,
check.names    = FALSE
)
}
add_row("2SLS",       iv$coef,                 iv$se,    "—")
add_row("τ_cb_u",     res$estimates["tau_cb_u"],  res$se["tau_cb_u"],  "✓")
add_row("τ_ml_u",     res$estimates["tau_ml_u"],  res$se["tau_ml_u"],  "✓")
add_row("τ_ml_a10",   res$estimates["tau_ml_a10"], res$se["tau_ml_a10"], "✓")
add_row("τ_ml_a",     res$estimates["tau_ml_a"],  res$se["tau_ml_a"],  "✗")
add_row("τ_ml_t",     res$estimates["tau_ml_t"],  res$se["tau_ml_t"],  "✗")
add_row("τ_ml_a0",    res$estimates["tau_ml_a0"], res$se["tau_ml_a0"], "✗")
}
}
rep_table <- do.call(rbind, rows)
rep_table %>%
kbl(align = c("l","l","l","c","r","r","r","c"),
caption = "Table 1 — Replication of SUW (2025) Table 2: Causal Effects of Vietnam Military Service on Log Wages") %>%
kable_styling(bootstrap_options = c("striped","hover","condensed"),
full_width = TRUE, font_size = 13) %>%
column_spec(5:7, monospace = TRUE) %>%
row_spec(which(rep_table$Normalized == "✓"), background = "#f0f8ff") %>%
row_spec(which(rep_table$Normalized == "✗"), background = "#fff9f0") %>%
footnote(general = "Blue rows: normalized (translation-invariant) estimators. Orange rows: unnormalized estimators. SE: analytical M-estimation sandwich (kappa); HC1-robust (2SLS). Stars: * p<0.10, ** p<0.05, *** p<0.01.")
p_ml_cub <- logit_mle(Z_sipp, X2)
kw_cub   <- kappa_outcome_weights(Z_sipp, D_sipp, p_ml_cub)
p_cb_cub <- get_cbps_p(Z_sipp, X2)
kw_cb_cub <- kappa_outcome_weights(Z_sipp, D_sipp, p_cb_cub)
ti_rows <- list(
doubleml_translation_row("τ_cb_u",   kw_cb_cub$w_u,   Y_dol, Y_cnt, k),
doubleml_translation_row("τ_ml_u",   kw_cub$w_u,      Y_dol, Y_cnt, k),
doubleml_translation_row("τ_ml_a10", kw_cub$w_a10,    Y_dol, Y_cnt, k),
doubleml_translation_row("τ_ml_a",   kw_cub$w_a,      Y_dol, Y_cnt, k),
doubleml_translation_row("τ_ml_t",   kw_cub$w_a1,     Y_dol, Y_cnt, k),
doubleml_translation_row("τ_ml_a0",  kw_cub$w_a0,     Y_dol, Y_cnt, k)
)
ti_cub <- do.call(rbind, ti_rows)
ti_cub %>%
kbl(caption = "Translation Invariance — Cubic Age Specification",
align = c("l","r","r","r","r","c")) %>%
kable_styling(bootstrap_options = c("striped","hover","condensed"),
full_width = FALSE, font_size = 13) %>%
row_spec(which(ti_cub$Match == TRUE),  background = "#eafbea") %>%
row_spec(which(ti_cub$Match == FALSE), background = "#fff0f0") %>%
footnote(general = "Diff_actual = Cents − Dollars. Diff_pred = Σωᵢ × log(100). Match = TRUE means the estimator is translation invariant.")
p_ml_sat  <- logit_mle(Z_sipp, X3)
kw_sat    <- kappa_outcome_weights(Z_sipp, D_sipp, p_ml_sat)
p_cb_sat  <- get_cbps_p(Z_sipp, X3)
kw_cb_sat <- kappa_outcome_weights(Z_sipp, D_sipp, p_cb_sat)
ti_rows_sat <- list(
doubleml_translation_row("τ_cb_u",   kw_cb_sat$w_u,  Y_dol, Y_cnt, k),
doubleml_translation_row("τ_ml_u",   kw_sat$w_u,     Y_dol, Y_cnt, k),
doubleml_translation_row("τ_ml_a10", kw_sat$w_a10,   Y_dol, Y_cnt, k),
doubleml_translation_row("τ_ml_a",   kw_sat$w_a,     Y_dol, Y_cnt, k),
doubleml_translation_row("τ_ml_t",   kw_sat$w_a1,    Y_dol, Y_cnt, k),
doubleml_translation_row("τ_ml_a0",  kw_sat$w_a0,    Y_dol, Y_cnt, k)
)
ti_sat <- do.call(rbind, ti_rows_sat)
ti_sat %>%
kbl(caption = "Translation Invariance — Saturated Age Specification",
align = c("l","r","r","r","r","c")) %>%
kable_styling(bootstrap_options = c("striped","hover","condensed"),
full_width = FALSE, font_size = 13) %>%
row_spec(which(ti_sat$Match == TRUE),  background = "#eafbea") %>%
row_spec(which(ti_sat$Match == FALSE), background = "#fff0f0") %>%
footnote(general = "Diff_actual = Cents − Dollars. Diff_pred = Σωᵢ × log(100). Match = TRUE means the estimator is translation invariant.")
set.seed(42)
dml_cub <- dml_with_smoother(Y_dol, D_sipp, X_dml_cub, Z_sipp,
n_cf_folds = 5, tune.parameters = "all")
res_cub <- summary(dml_cub)
omega_cub <- get_outcome_weights(dml_cub)
check_omega_rows(omega_cub)
w_plriv_cub    <- as.vector(omega_cub$omega["PLR-IV",    ])
w_waldaipw_cub <- as.vector(omega_cub$omega["Wald-AIPW", ])
res_cub[c("PLR-IV", "Wald-AIPW"), , drop = FALSE] %>%
as.data.frame() %>%
tibble::rownames_to_column("Estimator") %>%
kbl(caption = "DML Point Estimates — Cubic Age (log wages, dollars)",
digits = 4, align = c("l","r","r","r","r")) %>%
kable_styling(bootstrap_options = c("striped","hover","condensed"),
full_width = FALSE, font_size = 13)
