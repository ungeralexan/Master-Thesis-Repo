top_abs_kappa_summary <- function(data, kappa_name, top_n = c(5, 10, 20, 50)) {

  abs_k <- abs(data[[kappa_name]])
  total_abs <- sum(abs_k, na.rm = TRUE)

  out <- data.frame()

  ord <- order(abs_k, decreasing = TRUE)

  for (n_top in top_n) {
    idx <- ord[seq_len(min(n_top, length(ord)))]

    row <- data.frame(
      Kappa = kappa_name,
      Top_n = n_top,
      Share_abs_kappa = sum(abs_k[idx], na.rm = TRUE) / total_abs,
      Min_kappa_top = min(data[[kappa_name]][idx], na.rm = TRUE),
      Max_kappa_top = max(data[[kappa_name]][idx], na.rm = TRUE),
      Mean_pZ_top = mean(data$pZ_card[idx], na.rm = TRUE),
      Share_Z0_D1_somecol_top =
        mean(data$nearc4[idx] == 0 & data$somecol[idx] == 1, na.rm = TRUE),
      Share_Z0_D1_educ16_top =
        mean(data$nearc4[idx] == 0 & data$educ16[idx] == 1, na.rm = TRUE)
    )

    out <- rbind(out, row)
  }

  return(out)
}

