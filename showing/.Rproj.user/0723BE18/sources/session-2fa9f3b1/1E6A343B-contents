# ==============================================================================
# FULL DIAGNOSTIC BLOCK — High p(Z|X), Z = 0, D = 1, and kappa leverage
# ==============================================================================
# Purpose:
#   Diagnose whether low ESS / unstable kappa profiles are driven by observations
#   with high predicted probability of Z = 1, but observed Z = 0 and D = 1.
#
# Interpretation:
#   If p_i = P(Z_i = 1 | X_i) is high, but Z_i = 0 and D_i = 1, then
#
#       kappa_i = 1 - D_i(1-Z_i)/(1-p_i) - (1-D_i)Z_i/p_i
#
#   becomes very negative because the term 1/(1-p_i) is large.
# ==============================================================================


# ------------------------------------------------------------------------------
# 0. Basic safety checks
# ------------------------------------------------------------------------------

required_vars <- c(
  "nearc4", "somecol", "educ16",
  "black", "south", "smsa", "smsa66",
  "reg661", "reg662", "reg663", "reg664",
  "reg665", "reg666", "reg667", "reg668"
)

