# ------------------------------------------------------------------------------
# 1. Helper: robust logit propensity score
# ------------------------------------------------------------------------------

safe_logit <- function(eta) {
  eta <- pmin(pmax(eta, -35), 35)
  1 / (1 + exp(-eta))
}

logit_mle <- function(Z, X) {
  Z <- as.numeric(Z)
  X <- as.matrix(X)

  fit <- glm.fit(
    x = X,
    y = Z,
    family = binomial(link = "logit")
  )

  beta <- coef(fit)
  beta[is.na(beta)] <- 0

  p <- as.vector(safe_logit(X %*% beta))
  p <- pmin(pmax(p, 1e-8), 1 - 1e-8)

  return(p)
}


# ------------------------------------------------------------------------------
# 2. Helper: Abadie kappa for complier moments
# ------------------------------------------------------------------------------

kappa_complier <- function(Z, D, p) {
  Z <- as.numeric(Z)
  D <- as.numeric(D)
  p <- as.numeric(p)

  p <- pmin(pmax(p, 1e-8), 1 - 1e-8)

  1 -
    D * (1 - Z) / (1 - p) -
    (1 - D) * Z / p
}


