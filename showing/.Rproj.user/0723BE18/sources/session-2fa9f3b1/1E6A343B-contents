# ==============================================================================
# CBPS vs. MLE propensity score diagnostic — Card (1995)
# ==============================================================================
# Purpose:
#   Compare kappa weights and ESS under MLE logit vs. CBPS propensity scores
#   for both the Card and Kitagawa covariate specifications.
#
#   Key question: is the extreme-weight / low-ESS problem a structural overlap
#   issue (data), or does the MLE amplify it relative to CBPS?
#
# Requires:
#   - card_clean  : the cleaned Card dataset (with nearc4, somecol, educ16,
#                   all covariate columns, and Y in log-dollars)
#   - All functions from functions_card.R already sourced:
#       logit_mle(), get_cbps_p(), kappa_outcome_weights(), weight_diag()
#       safe_logit(), prep_design_for_mest(), fit_cbps_alpha()
# ==============================================================================


# ------------------------------------------------------------------------------
# 0.  Grab the core vectors (adjust names if yours differ)
# ------------------------------------------------------------------------------

Z  <- as.numeric(card_clean$nearc4)
D1 <- as.integer(card_clean$somecol)
D2 <- as.integer(card_clean$educ16)
Y  <- card_clean$lwage          # log wage in dollars — adjust if named differently


# ------------------------------------------------------------------------------
# 1.  Design matrices — exactly as in your main analysis
# ------------------------------------------------------------------------------

X_card_ps <- model.matrix(
  ~ black + south + smsa + smsa66 +
    reg661 + reg662 + reg663 + reg664 +
    reg665 + reg666 + reg667 + reg668,
  data = card_clean
)

X_kit_ps <- model.matrix(
  ~ black + south + smsa + smsa66 + south66,
  data = card_clean
)


# ------------------------------------------------------------------------------
# 2.  Estimate propensity scores: MLE and CBPS, both specs
# ------------------------------------------------------------------------------

cat("Estimating propensity scores...\n")

p_card_ml  <- logit_mle(Z, X_card_ps)
p_kit_ml   <- logit_mle(Z, X_kit_ps)

cat("  MLE done. Fitting CBPS (Card spec)...\n")
cbps_card_fit <- fit_cbps_alpha(Z, X_card_ps)
p_card_cb     <- cbps_card_fit$p
cat(sprintf("  CBPS Card  — converged: %s, max moment: %.2e\n",
            cbps_card_fit$converged, cbps_card_fit$max_moment))

cat("  Fitting CBPS (Kitagawa spec)...\n")
cbps_kit_fit <- fit_cbps_alpha(Z, X_kit_ps)
p_kit_cb     <- cbps_kit_fit$p
cat(sprintf("  CBPS Kit   — converged: %s, max moment: %.2e\n\n",
            cbps_kit_fit$converged, cbps_kit_fit$max_moment))


# ------------------------------------------------------------------------------
# 3.  Propensity score distribution comparison
# ------------------------------------------------------------------------------

cat(strrep("=", 65), "\n")
cat("PROPENSITY SCORE DISTRIBUTIONS: P(Z=1|X)\n")
cat(strrep("=", 65), "\n\n")

ps_summary <- function(p, label) {
  qs <- quantile(p, probs = c(0, 0.01, 0.05, 0.10, 0.25, 0.50,
                               0.75, 0.90, 0.95, 0.99, 1))
  cat(sprintf("%-30s\n", label))
  cat(sprintf("  Min / 1pct / 5pct  : %.4f / %.4f / %.4f\n",
              qs["0%"], qs["1%"], qs["5%"]))
  cat(sprintf("  Q1 / Median / Q3   : %.4f / %.4f / %.4f\n",
              qs["25%"], qs["50%"], qs["75%"]))
  cat(sprintf("  95pct / 99pct / Max: %.4f / %.4f / %.4f\n",
              qs["95%"], qs["99%"], qs["100%"]))
  cat(sprintf("  Std dev            : %.4f\n", sd(p)))
  cat(sprintf("  pct below 0.10     : %.1f%%\n", 100 * mean(p < 0.10)))
  cat(sprintf("  pct below 0.20     : %.1f%%\n", 100 * mean(p < 0.20)))
  cat(sprintf("  pct above 0.80     : %.1f%%\n", 100 * mean(p > 0.80)))
  cat(sprintf("  pct above 0.90     : %.1f%%\n", 100 * mean(p > 0.90)))
  cat(sprintf("  pct above 0.93     : %.1f%%  <- the κ=-13.9 threshold\n",
              100 * mean(p > 0.93)))
  cat("\n")
}

ps_summary(p_card_ml, "Card spec  — MLE logit")
ps_summary(p_card_cb, "Card spec  — CBPS")
ps_summary(p_kit_ml,  "Kitagawa spec — MLE logit")
ps_summary(p_kit_cb,  "Kitagawa spec — CBPS")


# ------------------------------------------------------------------------------
# 4.  Kappa weights: MLE vs CBPS, Card vs Kitagawa, D1 vs D2
# ------------------------------------------------------------------------------

cat(strrep("=", 65), "\n")
cat("KAPPA WEIGHT DIAGNOSTICS\n")
cat(strrep("=", 65), "\n\n")

kappa_diag <- function(Z, D, p, label) {
  kw <- 1 - D * (1 - Z) / (1 - p) - (1 - D) * Z / p
  cat(sprintf("%-45s\n", label))
  cat(sprintf("  mean(kappa)      : %.6f\n", mean(kw)))
  cat(sprintf("  min(kappa)       : %.4f\n", min(kw)))
  cat(sprintf("  max(kappa)       : %.4f\n", max(kw)))
  cat(sprintf("  share negative   : %.2f%%\n", 100 * mean(kw < 0)))
  cat(sprintf("  share < -5       : %.2f%%  <- extreme leverage\n",
              100 * mean(kw < -5)))
  cat(sprintf("  share < -10      : %.2f%%\n", 100 * mean(kw < -10)))
  cat("\n")
}

kappa_diag(Z, D1, p_card_ml, "D1=somecol | Card spec  | MLE")
kappa_diag(Z, D1, p_card_cb, "D1=somecol | Card spec  | CBPS")
kappa_diag(Z, D1, p_kit_ml,  "D1=somecol | Kitagawa   | MLE")
kappa_diag(Z, D1, p_kit_cb,  "D1=somecol | Kitagawa   | CBPS")
kappa_diag(Z, D2, p_card_ml, "D2=educ16  | Card spec  | MLE")
kappa_diag(Z, D2, p_card_cb, "D2=educ16  | Card spec  | CBPS")
kappa_diag(Z, D2, p_kit_ml,  "D2=educ16  | Kitagawa   | MLE")
kappa_diag(Z, D2, p_kit_cb,  "D2=educ16  | Kitagawa   | CBPS")


