probs = c(0, 0.001, 0.01, 0.05, 0.10, 0.25,
0.50, 0.75, 0.90, 0.95, 0.99, 0.999, 1),
na.rm = TRUE))
cat("\n")
# ------------------------------------------------------------------------------
# 4. Compute kappa for D1 = somecol and D2 = educ16
# ------------------------------------------------------------------------------
card_clean$kappa_somecol_card <- kappa_complier(
Z = card_clean$nearc4,
D = card_clean$somecol,
p = card_clean$pZ_card
)
card_clean$kappa_educ16_card <- kappa_complier(
Z = card_clean$nearc4,
D = card_clean$educ16,
p = card_clean$pZ_card
)
cat("Kappa summary for D1 = somecol:\n")
print(summary(card_clean$kappa_somecol_card))
cat(sprintf("mean(kappa) = %.6f\n", mean(card_clean$kappa_somecol_card)))
cat(sprintf("sum(kappa)  = %.6f\n", sum(card_clean$kappa_somecol_card)))
cat(sprintf("share negative kappa = %.2f%%\n\n",
100 * mean(card_clean$kappa_somecol_card < 0)))
cat("Kappa summary for D2 = educ16:\n")
print(summary(card_clean$kappa_educ16_card))
cat(sprintf("mean(kappa) = %.6f\n", mean(card_clean$kappa_educ16_card)))
cat(sprintf("sum(kappa)  = %.6f\n", sum(card_clean$kappa_educ16_card)))
cat(sprintf("share negative kappa = %.2f%%\n\n",
100 * mean(card_clean$kappa_educ16_card < 0)))
# ------------------------------------------------------------------------------
# 5. First-stage checks
# ------------------------------------------------------------------------------
cat("Raw first-stage checks:\n\n")
cat("D1 = somecol:\n")
print(with(card_clean, tapply(somecol, nearc4, mean)))
cat(sprintf("First stage D1 = %.6f\n\n",
with(card_clean, mean(somecol[nearc4 == 1]) -
mean(somecol[nearc4 == 0]))))
cat("D2 = educ16:\n")
print(with(card_clean, tapply(educ16, nearc4, mean)))
cat(sprintf("First stage D2 = %.6f\n\n",
with(card_clean, mean(educ16[nearc4 == 1]) -
mean(educ16[nearc4 == 0]))))
# ------------------------------------------------------------------------------
# 6. Main diagnostic:
#    high p(Z=1|X), but observed Z=0 and D=1
# ------------------------------------------------------------------------------
high_p_Z0_D1_diagnostic <- function(data, D_name, kappa_name,
p_name = "pZ_card",
Z_name = "nearc4",
cutoffs = c(0.70, 0.80, 0.90, 0.95)) {
out <- data.frame()
for (cut in cutoffs) {
idx_high <- data[[p_name]] >= cut
idx_risk <- data[[p_name]] >= cut &
data[[Z_name]] == 0 &
data[[D_name]] == 1
row <- data.frame(
Treatment = D_name,
Cutoff = cut,
N_total = nrow(data),
N_high_p = sum(idx_high, na.rm = TRUE),
Share_high_p_full = mean(idx_high, na.rm = TRUE),
N_high_p_Z0_D1 = sum(idx_risk, na.rm = TRUE),
Share_high_p_Z0_D1_full = mean(idx_risk, na.rm = TRUE),
Share_Z0_D1_among_high_p =
ifelse(sum(idx_high, na.rm = TRUE) > 0,
sum(idx_risk, na.rm = TRUE) / sum(idx_high, na.rm = TRUE),
NA_real_),
Min_kappa_in_risk_group =
ifelse(sum(idx_risk, na.rm = TRUE) > 0,
min(data[[kappa_name]][idx_risk], na.rm = TRUE),
NA_real_),
Mean_kappa_in_risk_group =
ifelse(sum(idx_risk, na.rm = TRUE) > 0,
mean(data[[kappa_name]][idx_risk], na.rm = TRUE),
NA_real_),
Max_abs_kappa_in_risk_group =
ifelse(sum(idx_risk, na.rm = TRUE) > 0,
max(abs(data[[kappa_name]][idx_risk]), na.rm = TRUE),
NA_real_)
)
out <- rbind(out, row)
}
return(out)
}
diag_somecol <- high_p_Z0_D1_diagnostic(
data = card_clean,
D_name = "somecol",
kappa_name = "kappa_somecol_card"
)
diag_educ16 <- high_p_Z0_D1_diagnostic(
data = card_clean,
D_name = "educ16",
kappa_name = "kappa_educ16_card"
)
cat("Diagnostic: high p(Z=1|X), observed Z=0, D=1 — D1 = somecol\n")
print(diag_somecol)
cat("\n")
cat("Diagnostic: high p(Z=1|X), observed Z=0, D=1 — D2 = educ16\n")
print(diag_educ16)
cat("\n")
# ------------------------------------------------------------------------------
# 7. Symmetric diagnostic:
#    low p(Z=1|X), but observed Z=1 and D=0
# ------------------------------------------------------------------------------
low_p_Z1_D0_diagnostic <- function(data, D_name, kappa_name,
p_name = "pZ_card",
Z_name = "nearc4",
cutoffs = c(0.30, 0.20, 0.10, 0.05)) {
out <- data.frame()
for (cut in cutoffs) {
idx_low <- data[[p_name]] <= cut
idx_risk <- data[[p_name]] <= cut &
data[[Z_name]] == 1 &
data[[D_name]] == 0
row <- data.frame(
Treatment = D_name,
Cutoff = cut,
N_total = nrow(data),
N_low_p = sum(idx_low, na.rm = TRUE),
Share_low_p_full = mean(idx_low, na.rm = TRUE),
N_low_p_Z1_D0 = sum(idx_risk, na.rm = TRUE),
Share_low_p_Z1_D0_full = mean(idx_risk, na.rm = TRUE),
Share_Z1_D0_among_low_p =
ifelse(sum(idx_low, na.rm = TRUE) > 0,
sum(idx_risk, na.rm = TRUE) / sum(idx_low, na.rm = TRUE),
NA_real_),
Min_kappa_in_risk_group =
ifelse(sum(idx_risk, na.rm = TRUE) > 0,
min(data[[kappa_name]][idx_risk], na.rm = TRUE),
NA_real_),
Mean_kappa_in_risk_group =
ifelse(sum(idx_risk, na.rm = TRUE) > 0,
mean(data[[kappa_name]][idx_risk], na.rm = TRUE),
NA_real_),
Max_abs_kappa_in_risk_group =
ifelse(sum(idx_risk, na.rm = TRUE) > 0,
max(abs(data[[kappa_name]][idx_risk]), na.rm = TRUE),
NA_real_)
)
out <- rbind(out, row)
}
return(out)
}
diag_low_somecol <- low_p_Z1_D0_diagnostic(
data = card_clean,
D_name = "somecol",
kappa_name = "kappa_somecol_card"
)
diag_low_educ16 <- low_p_Z1_D0_diagnostic(
data = card_clean,
D_name = "educ16",
kappa_name = "kappa_educ16_card"
)
cat("Diagnostic: low p(Z=1|X), observed Z=1, D=0 — D1 = somecol\n")
print(diag_low_somecol)
cat("\n")
cat("Diagnostic: low p(Z=1|X), observed Z=1, D=0 — D2 = educ16\n")
print(diag_low_educ16)
cat("\n")
# ------------------------------------------------------------------------------
# 8. Inspect the most negative kappa observations
# ------------------------------------------------------------------------------
inspect_vars <- c(
"pZ_card", "nearc4", "somecol", "educ16",
"kappa_somecol_card", "kappa_educ16_card",
"black", "south", "smsa", "smsa66",
"reg661", "reg662", "reg663", "reg664",
"reg665", "reg666", "reg667", "reg668"
)
inspect_vars <- intersect(inspect_vars, names(card_clean))
cat("20 most negative kappa observations for D1 = somecol:\n")
print(
head(
card_clean[order(card_clean$kappa_somecol_card), inspect_vars],
20
)
)
cat("\n")
cat("20 most negative kappa observations for D2 = educ16:\n")
print(
head(
card_clean[order(card_clean$kappa_educ16_card), inspect_vars],
20
)
)
cat("\n")
# ------------------------------------------------------------------------------
# 9. Optional: aggregate the top absolute kappa contributors
# ------------------------------------------------------------------------------
top_abs_kappa_summary <- function(data, kappa_name, top_n = c(5, 10, 20, 50)) {
abs_k <- abs(data[[kappa_name]])
total_abs <- sum(abs_k, na.rm = TRUE)
out <- data.frame()
ord <- order(abs_k, decreasing = TRUE)
for (n_top in top_n) {
idx <- ord[seq_len(min(n_top, length(ord)))]
row <- data.frame(
Kappa = kappa_name,
Top_n = n_top,
Share_abs_kappa = sum(abs_k[idx], na.rm = TRUE) / total_abs,
Min_kappa_top = min(data[[kappa_name]][idx], na.rm = TRUE),
Max_kappa_top = max(data[[kappa_name]][idx], na.rm = TRUE),
Mean_pZ_top = mean(data$pZ_card[idx], na.rm = TRUE),
Share_Z0_D1_somecol_top =
mean(data$nearc4[idx] == 0 & data$somecol[idx] == 1, na.rm = TRUE),
Share_Z0_D1_educ16_top =
mean(data$nearc4[idx] == 0 & data$educ16[idx] == 1, na.rm = TRUE)
)
out <- rbind(out, row)
}
return(out)
}
cat("Top absolute-kappa concentration — D1 = somecol:\n")
print(top_abs_kappa_summary(card_clean, "kappa_somecol_card"))
cat("\n")
cat("Top absolute-kappa concentration — D2 = educ16:\n")
print(top_abs_kappa_summary(card_clean, "kappa_educ16_card"))
cat("\n")
# ==============================================================================
# BLOCK G — First-stage heterogeneity across covariates
# ==============================================================================
# WHY: The Love plots in card_22_double_ml.R showed that region dummies cause
# the most trouble.  The reason is that the first stage — the response of D to Z
# — is heterogeneous across regions.  If college proximity matters more in some
# regions than others, then the IV effectively identifies the LATE for a
# geographically specific complier subpopulation.  Estimators that don't
# account for this will show poor balance on region dummies.
#
# Concretely: if nearc4=1 predicts some_college much more strongly in the
# South than in the Northeast, the weighted sample will over-represent Southern
# compliers relative to the overall treated population.
# ==============================================================================
cat(strrep("-", 60), "\n")
cat("BLOCK G — First-stage heterogeneity across subgroups\n")
cat(strrep("-", 60), "\n\n")
cat("First-stage P(D1=1|Z=1) - P(D1=1|Z=0) by subgroup:\n")
cat("(Heterogeneity here = heterogeneous complier population across groups)\n\n")
subgroups <- list(
"black = 1"      = card_clean$black == 1,
"black = 0"      = card_clean$black == 0,
"south66 = 1"    = card_clean$south66 == 1,
"south66 = 0"    = card_clean$south66 == 0,
"smsa66 = 1"     = card_clean$smsa66 == 1,
"smsa66 = 0"     = card_clean$smsa66 == 0
)
# Also region dummies
region_vars <- paste0("reg66", 1:8)
for (rv in region_vars) {
if (rv %in% names(card_clean)) {
subgroups[[paste0(rv, " = 1")]] <- card_clean[[rv]] == 1
}
}
cat(sprintf("%-22s  %5s  %6s  %6s  %8s\n",
"Subgroup", "N", "fs_d1", "fs_d2", "Ratio"))
cat(strrep("-", 52), "\n")
for (sg_name in names(subgroups)) {
idx  <- subgroups[[sg_name]]
n_sg <- sum(idx)
if (n_sg < 30) {
cat(sprintf("%-22s  %5d  (too small)\n", sg_name, n_sg))
next
}
p1_d1 <- mean(D1[idx & Z == 1])
p0_d1 <- mean(D1[idx & Z == 0])
p1_d2 <- mean(D2[idx & Z == 1])
p0_d2 <- mean(D2[idx & Z == 0])
fs_sg_d1 <- p1_d1 - p0_d1
fs_sg_d2 <- p1_d2 - p0_d2
ratio_d1 <- if (abs(fs_d1) > 1e-6) fs_sg_d1 / fs_d1 else NA
cat(sprintf("%-22s  %5d  %6.4f  %6.4f  %8.3f\n",
sg_name, n_sg, fs_sg_d1, fs_sg_d2,
ifelse(is.na(ratio_d1), NA, ratio_d1)))
}
cat("\n")
cat("KEY INSIGHT:\n")
cat("  Subgroups with fs/fs_overall > 1.5 or < 0.5 are 'over-represented'\n")
cat("  or 'under-represented' in the complier population relative to their\n")
cat("  sample share.  This heterogeneity is what makes the Love plots look\n")
cat("  bad on region dummies: the kappa weights effectively up-weight the\n")
cat("  high-compliance regions and down-weight the low-compliance ones,\n")
cat("  creating imbalance on any covariate that correlates with region.\n\n")
# ==============================================================================
# BLOCK G2 — Covariate-adjusted first-stage heterogeneity
# ==============================================================================
# GOAL:
#   Estimate whether the first stage differs across covariate subgroups,
#   after controlling for the Card covariates.
#
# Raw subgroup first stage:
#   fs_g = P(D=1 | Z=1, G=g) - P(D=1 | Z=0, G=g)
#
# Covariate-adjusted first stage:
#   D_i = alpha + rho Z_i + X_i beta + theta (Z_i * G_i) + gamma G_i + u_i
#
# Then:
#   fs(G=0) = rho
#   fs(G=1) = rho + theta
#
# For region heterogeneity, use region as a factor:
#   D_i = alpha + region_i + Z_i:region_i + other controls + u_i
#
# Then each region-specific first stage is the coefficient on Z within that
# region, controlling for the remaining covariates.
# ==============================================================================
cat(strrep("-", 60), "\n")
cat("BLOCK G2 — Covariate-adjusted first-stage heterogeneity\n")
cat(strrep("-", 60), "\n\n")
# ------------------------------------------------------------------------------
# 0. Make sure variables are numeric
# ------------------------------------------------------------------------------
card_clean$Z_nearc4 <- as.numeric(card_clean$nearc4)
card_clean$D_somecol <- as.numeric(card_clean$somecol)
card_clean$D_educ16  <- as.numeric(card_clean$educ16)
# ------------------------------------------------------------------------------
# 1. Construct a region factor from reg661-reg668
# ------------------------------------------------------------------------------
region_vars <- paste0("reg66", 1:8)
region_vars <- region_vars[region_vars %in% names(card_clean)]
card_clean$region66 <- NA_character_
for (rv in region_vars) {
card_clean$region66[card_clean[[rv]] == 1] <- rv
}
card_clean$region66 <- factor(card_clean$region66)
cat("Region counts:\n")
print(table(card_clean$region66, useNA = "ifany"))
cat("\n")
# ------------------------------------------------------------------------------
# 2. Function for binary subgroup heterogeneity
# ------------------------------------------------------------------------------
adjusted_fs_binary <- function(data, D_name, G_name, controls) {
# Formula:
# D ~ Z * G + controls
fml <- as.formula(
paste0(
D_name, " ~ Z_nearc4 * ", G_name, " + ",
paste(controls, collapse = " + ")
)
)
fit <- lm(fml, data = data)
co <- coef(fit)
vc <- vcov(fit)
# Main Z coefficient = first stage for G=0
beta_Z <- co["Z_nearc4"]
# Interaction coefficient = difference in first stage for G=1 vs G=0
int_name_1 <- paste0("Z_nearc4:", G_name)
int_name_2 <- paste0(G_name, ":Z_nearc4")
int_name <- if (int_name_1 %in% names(co)) int_name_1 else int_name_2
beta_int <- if (int_name %in% names(co)) co[int_name] else 0
fs_g0 <- beta_Z
fs_g1 <- beta_Z + beta_int
se_g0 <- sqrt(vc["Z_nearc4", "Z_nearc4"])
# Delta method for beta_Z + beta_int
if (int_name %in% rownames(vc)) {
se_g1 <- sqrt(
vc["Z_nearc4", "Z_nearc4"] +
vc[int_name, int_name] +
2 * vc["Z_nearc4", int_name]
)
} else {
se_g1 <- se_g0
}
out <- data.frame(
Treatment = D_name,
Subgroup = G_name,
Group = c("0", "1"),
N = c(sum(data[[G_name]] == 0, na.rm = TRUE),
sum(data[[G_name]] == 1, na.rm = TRUE)),
Adj_first_stage = c(fs_g0, fs_g1),
SE = c(se_g0, se_g1),
t_value = c(fs_g0 / se_g0, fs_g1 / se_g1)
)
return(out)
}
# ------------------------------------------------------------------------------
# 3. Function for region-specific adjusted first stages
# ------------------------------------------------------------------------------
adjusted_fs_region <- function(data, D_name, controls_other) {
# Formula:
# D ~ 0 + region66 + Z:region66 + other controls
#
# Using 0 + region66 creates one intercept per region.
# Z_nearc4:region66 gives one first-stage coefficient per region.
fml <- as.formula(
paste0(
D_name, " ~ 0 + region66 + Z_nearc4:region66 + ",
paste(controls_other, collapse = " + ")
)
)
fit <- lm(fml, data = data)
co <- coef(fit)
vc <- vcov(fit)
regions <- levels(data$region66)
out <- data.frame()
for (r in regions) {
coef_name <- paste0("region66", r, ":Z_nearc4")
coef_name_alt <- paste0("Z_nearc4:region66", r)
cn <- if (coef_name %in% names(co)) coef_name else coef_name_alt
if (!cn %in% names(co)) next
fs_r <- co[cn]
se_r <- sqrt(vc[cn, cn])
row <- data.frame(
Treatment = D_name,
Region = r,
N = sum(data$region66 == r, na.rm = TRUE),
N_Z1 = sum(data$region66 == r & data$Z_nearc4 == 1, na.rm = TRUE),
N_Z0 = sum(data$region66 == r & data$Z_nearc4 == 0, na.rm = TRUE),
Adj_first_stage = fs_r,
SE = se_r,
t_value = fs_r / se_r
)
out <- rbind(out, row)
}
return(out)
}
# ------------------------------------------------------------------------------
# 4. Define controls
# ------------------------------------------------------------------------------
# For binary subgroup interactions, include standard Card controls.
# Important: when G is one of the controls, remove it from the controls list
# to avoid duplication.
base_controls <- c(
"exper", "expersq",
"black", "south", "smsa", "smsa66",
"reg661", "reg662", "reg663", "reg664",
"reg665", "reg666", "reg667", "reg668"
)
# For region-specific heterogeneity, do NOT include individual region dummies
# because region66 already absorbs them.
controls_for_region <- c(
"exper", "expersq",
"black", "south", "smsa", "smsa66"
)
# ------------------------------------------------------------------------------
# 5. Binary subgroup adjusted first stages
# ------------------------------------------------------------------------------
binary_subgroups <- c("black", "south", "smsa", "smsa66")
cat("Adjusted first-stage heterogeneity: binary subgroups\n\n")
binary_results <- data.frame()
for (D_name in c("D_somecol", "D_educ16")) {
for (G_name in binary_subgroups) {
controls_use <- setdiff(base_controls, G_name)
tmp <- adjusted_fs_binary(
data = card_clean,
D_name = D_name,
G_name = G_name,
controls = controls_use
)
binary_results <- rbind(binary_results, tmp)
}
}
print(binary_results)
cat("\n")
# ------------------------------------------------------------------------------
# 6. Region-specific adjusted first stages
# ------------------------------------------------------------------------------
cat("Adjusted first-stage heterogeneity: regions\n\n")
region_results_somecol <- adjusted_fs_region(
data = card_clean,
D_name = "D_somecol",
controls_other = controls_for_region
)
region_results_educ16 <- adjusted_fs_region(
data = card_clean,
D_name = "D_educ16",
controls_other = controls_for_region
)
cat("D1 = somecol:\n")
print(region_results_somecol)
cat("\n")
cat("D2 = educ16:\n")
print(region_results_educ16)
cat("\n")
# ------------------------------------------------------------------------------
# 7. Add ratios relative to the overall adjusted first stage
# ------------------------------------------------------------------------------
fs_overall_somecol <- coef(lm(
D_somecol ~ Z_nearc4 + exper + expersq + black + south + smsa + smsa66 +
reg661 + reg662 + reg663 + reg664 + reg665 + reg666 + reg667 + reg668,
data = card_clean
))["Z_nearc4"]
fs_overall_educ16 <- coef(lm(
D_educ16 ~ Z_nearc4 + exper + expersq + black + south + smsa + smsa66 +
reg661 + reg662 + reg663 + reg664 + reg665 + reg666 + reg667 + reg668,
data = card_clean
))["Z_nearc4"]
region_results_somecol$Ratio_to_overall_adj <- region_results_somecol$Adj_first_stage / fs_overall_somecol
region_results_educ16$Ratio_to_overall_adj  <- region_results_educ16$Adj_first_stage / fs_overall_educ16
cat("Overall adjusted first stage:\n")
cat(sprintf("  D1 = somecol: %.6f\n", fs_overall_somecol))
cat(sprintf("  D2 = educ16 : %.6f\n\n", fs_overall_educ16))
cat("Region results with ratios — D1 = somecol:\n")
print(region_results_somecol)
cat("\n")
cat("Region results with ratios — D2 = educ16:\n")
print(region_results_educ16)
cat("\n")
# ------------------------------------------------------------------------------
# 8. Interpretation helper
# ------------------------------------------------------------------------------
cat("INTERPRETATION:\n")
cat("  Adj_first_stage is the covariate-adjusted effect of nearc4 on D within the subgroup/region.\n")
cat("  For binary groups, it comes from D ~ Z * G + controls.\n")
cat("  For regions, it comes from D ~ region + Z:region + controls.\n")
cat("  Large positive values mean the instrument creates many compliers in that group.\n")
cat("  Near-zero values mean weak/no first stage in that group.\n")
cat("  Negative values mean the raw/adjusted relationship reverses in that group; treat cautiously,\n")
cat("  especially when N_Z0 or N_Z1 is small.\n")
cat("  Ratio_to_overall_adj compares the region-specific first stage to the overall adjusted first stage.\n")
cat("  Values above 1 mean the region contributes more strongly to the complier margin than average.\n")
cat("  Values below 1 mean it contributes less strongly than average.\n")
